#!/bin/bash
set -e

PACKAGE_NAME="whisperkey"
EXTENSION_UUID="whisperkey@whisperkey.app"

# Get the real user
if [ "$EUID" -eq 0 ] && [ -z "$SUDO_USER" ]; then
    REAL_USER="$USER"
    REAL_HOME="$HOME"
else
    REAL_USER="${SUDO_USER:-$USER}"
    REAL_HOME=$(getent passwd "$REAL_USER" | cut -d: -f6)
fi

case "$1" in
    purge)
        echo "Purging WhisperKey configuration..."
        
        # Stop any lingering processes
        pkill -f whisperkey 2>/dev/null || true
        
        # Remove autostart file
        if [ -f "$REAL_HOME/.config/autostart/whisperkey.desktop" ]; then
            rm -f "$REAL_HOME/.config/autostart/whisperkey.desktop"
            echo "Removed autostart configuration"
        fi
        
        # Remove GNOME extension
        EXTENSION_DIR="$REAL_HOME/.local/share/gnome-shell/extensions/$EXTENSION_UUID"
        if [ -d "$EXTENSION_DIR" ]; then
            rm -rf "$EXTENSION_DIR"
            echo "Removed GNOME extension"
        fi
        
        # Uninstall pipx package
        if command -v pipx >/dev/null 2>&1; then
            su - "$REAL_USER" -c "pipx uninstall whisperkey 2>/dev/null || true"
            echo "Removed pipx installation"
        fi
        
        # Remove user data (optional - ask user)
        if [ -d "$REAL_HOME/.cache/whisperkey" ]; then
            echo "Note: User data in $REAL_HOME/.cache/whisperkey was preserved"
            echo "      Remove manually if desired: rm -rf $REAL_HOME/.cache/whisperkey"
        fi
        
        echo "WhisperKey purged successfully"
        ;;
        
    remove)
        echo "Removing WhisperKey..."
        # Stop processes after files are removed
        pkill -f whisperkey 2>/dev/null || true
        echo "WhisperKey removed (configuration preserved)"
        ;;
        
    upgrade|failed-upgrade|abort-install|abort-upgrade|disappear)
        # Don't kill during upgrade - new version is already in place
        echo "WhisperKey post-removal (configuration preserved)"
        ;;
        
    *)
        echo "postrm called with unknown argument \`$1'" >&2
        exit 1
        ;;
esac

exit 0


