Package: whisperkey
Version: 0.3.3
Section: sound
Priority: optional
Architecture: all
Depends: python3 (>= 3.11), python3-pip, python3-dev, portaudio19-dev, pipx, gnome-shell (>= 42), gir1.2-glib-2.0, ydotool, xdotool, libxcb-cursor0
